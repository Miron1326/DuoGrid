  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 71a55b0538d48354b87afab937af74d2, type: 3}
    m_FontSize: 45
    m_FontStyle: 3
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 50
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0421\u043F\u0440\u0430\u0432\u043A\u0430\n\n\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u043C 1 \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u043C
    \u0440\u0435\u0436\u0438\u043C\u0435\n\u0438\u0434\u0435\u0442 \u0447\u0435\u0440\u0435\u0437
    \u043A\u043D\u043E\u043F\u043A\u0438 WASD.\n\u0412 \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436 \u0434\u0432\u0430 \u0445\u043E\u0434\u0438\u0442
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0441\u0442\u0440\u0435\u043B\u043E\u0447\u043A\u0438.\n\u041E\u0431\u0430
    \u0438\u0433\u0440\u043E\u043A\u0430 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u0445\u043E\u0434\u0430 \u043C\u043E\u0433\u0443\u0442
    \u043D\u0430\u0436\u0430\u0442\u044C \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
    C \u0438 \u043D\u0430\u0447\u0430\u0442\u044C \u0441\u0442\u0440\u043E\u0438\u0442\u044C.\n\n\u0424\u0438\u043D\u0438\u0448
    \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043B\u044E\u0431\u043E\u0439 \u0438\u0433\u0440\u043E\u043A \u043D\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u0438\u043D \u0438 \u043D\u0430 \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0443
    \u0432\u0440\u0430\u0433\u0430.\n\n\u0415\u0449\u0435 \u043E\u0434\u043D\u0430
    \u0438\u0437 \u043C\u0435\u0445\u0430\u043D\u0438\u043A \u0438\u0433\u0440\u044B
    \u0442\u043E \u0447\u0442\u043E \u043A\u0442\u043E \u0431\u044B \u043D\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u043F\u043E\u043B\u0435 \u043B\u044E\u0431\u043E\u0439
    \u0438\u0433\u0440\u043E\u043A \u0431\u0443\u0434\u0435\u0442 \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0441 \u044D\u0442\u0438\u043C \u043F\u043E\u043B\u0435\u043C \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0432
    \u043D\u0430 \u043D\u0435\u0433\u043E.\n_________________________________\n\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u043F\u043E\u043B\u0435\u0439\n_________________________________\n\nDamage \u0423\u0440\u043E\u043D\u043D\u043E\u0435
    - \u043D\u0430\u043D\u043E\u0441\u0438\u0442 \u0443\u0440\u043E\u043D \u0438\u0433\u0440\u043E\u043A\u0443.\n\nFinish
    \u0424\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0435 - \u0414\u0430\u0435\u0442
    \u0438\u0433\u0440\u043E\u043A\u0443 \u043E\u0434\u043D\u043E \u043E\u0447\u043A\u043E
    \u043F\u043E\u0431\u0435\u0434\u0430 \u0438 \u0442\u0435\u043B\u0435\u043F\u043E\u0440\u0442\u0438\u0440\u0443\u0435\u0442
    \u0438\u0433\u0440\u043E\u043A\u0430 \u0432 \u0442\u043E\u0447\u043A\u0443 \u0441\u0442\u0430\u0440\u0442\u0430.\n\nPoison
    \u042F\u0434\u043E\u0432\u0438\u0442\u043E\u0435 - \u041E\u0442\u0440\u0430\u0432\u043B\u044F\u0435\u0442
    \u0438\u0433\u0440\u043E\u043A\u0430, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u043A\u043E\u0433\u0434\u0430 \u043F\u0440\u043E\u0439\u0434\u0435\u0442 4 \u0445\u043E\u0434\u0430
    \u0438\u0433\u0440\u043E\u043A \u043F\u043E\u043B\u0443\u0447\u0438\u0442 3 \u0443\u0440\u043E\u043D\u0430.\n\nAntidote
    \u041F\u0440\u043E\u0442\u0438\u0432\u043E\u044F\u0434\u0438\u0435 - \u0423\u0431\u0438\u0440\u0430\u0435\u0442
    \u044D\u0444\u0444\u0435\u043A\u0442 \u044F\u0434\u0430 \u0441 \u0438\u0433\u0440\u043E\u043A\u0430.\n\nWall
    \u0441\u0442\u0435\u043D\u0430 - \u0431\u043B\u043E\u043A\u0438\u0440\u0443\u0435\u0442
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u044F \u0438\u0433\u0440\u043E\u043A\u0430\n\nCapsule
    \u043A\u0430\u043F\u0441\u0443\u043B\u0430 - \u043C\u043E\u0436\u0435\u0442 \u043C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043A\u043B\u0435\u0442\u043A\u0438\n\n_________________________________\n\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\n_________________________________\n\n\u0412
    \u0438\u0433\u0440\u0435 \u0435\u0441\u0442\u044C \u0412\u0430\u043B\u044E\u0442\u0430
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0442\u0440\u0430\u0442\u0438\u0442\u0441\u044F
    \u043D\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    - \u0422\u0430\u043A\u0442\u044B\n\u0447\u0442\u043E\u0431\u044B \u0438\u0445
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043D\u0443\u0436\u043D\u043E
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0434\u0435\u043B\u0430\u0442\u044C
    \u043A\u0440\u043E\u043C\u0435 \u043A\u0430\u043A \u043D\u0430\u0436\u0430\u0442\u044C
    \u043D\u0430 \u043F\u0440\u043E\u0431\u0435\u043B. \u0410\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E
    \u043F\u0440\u0438 \u043D\u0430\u0436\u0430\u0442\u0438\u0438 \u0441\u0442\u043E\u044F
    \u043D\u0430 \u043A\u043B\u0435\u0442\u043A\u0435 \u043A\u043B\u0435\u0442\u043A\u0430
    \u0431\u0443\u0434\u0435\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F,
    \u0442\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u043C\u043E\u0436\u043D\u043E
    \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u044C \u0448\u0430\u0433\u043E\u0432
    \u0438 \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0437\u0430 \u043E\u0434\u0438\u043D
    \u0441\u0432\u043E\u0439 \u0445\u043E\u0434 \u043C\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0439.\n\n\u0412
    \u0438\u0433\u0440\u0435 \u0435\u0441\u0442\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u041A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\n\nv1.62 - \u0433\u0440\u0438\u0431\u043D\u043E\u0435
    \u043C\u0443\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\n\u043D\u0430
    \u043A\u0430\u0440\u0442\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0433\u0440\u0438\u0431\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u0443\u0442\u0438\u0440\u0443\u044E\u0442
    \u0432 \u043E\u0434\u043D\u043E\u0433\u043E \u043A\u0430\u043A\u0442\u0443\u0441\u0430
    \u043A\u043E\u0433\u0434\u0430 \u0440\u044F\u0434\u043E\u043C \u0441 \u043E\u0434\u043D\u0438\u043C
    \u0433\u0440\u0438\u0431\u043E\u043C \u0435\u0449\u0435 2 \u0438\u043B\u0438
    3 \u0442\u0430\u043A\u0438\u0445 \u0436\u0435.\n \u041A\u0430\u043A\u0442\u0443\u0441
    \u043D\u0430\u043D\u043E\u0441\u0438\u0442 \u043D\u0430 \u043A\u043B\u0435\u0442\u043A\u0430\u0445
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u0435\u0431\u044F, \u0432\u043E\u043A\u0440\u0443\u0433
    \u043C\u0435\u0441\u0442\u0430 \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F
    \u043A\u0430\u043A\u0442\u0443\u0441\u0430 \u0432\u0441\u0435 \u0431\u043B\u043E\u043A\u0438
    \u0441\u0442\u0430\u043D\u043E\u0432\u044F\u0442\u0441\u044F \u043E\u0431\u044B\u0447\u043D\u044B\u043C\u0438.\n\u0412
    \u044D\u0442\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A\u0430\u043A\u0442\u0443\u0441 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0439
    \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440 - \u043A\u0430\u043F\u0441\u0443\u043B\u044B.
    \u0438 \u043F\u043E\u0441\u043B\u0435 \u0442\u0440\u0451\u0445 \u0445\u043E\u0434\u043E\u0432
    \u0441 \u044D\u0442\u0438\u043C \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440\u043E\u043C
    \u043E\u0442 \u043B\u044E\u0431\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430.
    \u043A\u0430\u043A\u0442\u0443\u0441 \u043F\u0440\u043E\u0440\u043E\u0441\u0442\u0430\u0435\u0442
    \u0432 \u0445\u043E\u0434\u044F\u0449\u0435\u0433\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E
    \u043A\u0430\u043A\u0442\u0443\u0441\u0430.\n\u041E\u043D \u0434\u0435\u043B\u0430\u0435\u0442
    \u0442\u0430\u043A - \u0447\u0442\u043E \u043A\u043E\u0433\u0434\u0430 \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F
    \u0438\u0433\u0440\u043E\u043A\u0430 \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D \u0445\u043E\u0434\u0438\u0442, \u044D\u0442\u043E\u0442 \u0438\u0433\u0440\u043E\u043A
    \u0442\u0435\u0440\u044F\u0435\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u0442\u0430\u0432\u0438\u0442\u044C \u043B\u044E\u0431\u044B\u0435 \u043A\u043B\u0435\u0442\u043A\u0438(\u043A\u0440\u043E\u043C\u0435
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432) \u043D\u0430 3 \u0445\u043E\u0434\u0430,
    \u0441\u0430\u043C \u043A\u0430\u043A\u0442\u0443\u0441 \u0432 \u044D\u0442\u043E\u0442
    \u043C\u043E\u043C\u0435\u043D\u0442 \u0441\u0442\u0430\u043D\u0438\u0442\u0441\u044F.
    \u042D\u0442\u043E\u0433\u043E \u043A\u0430\u043A\u0442\u0443\u0441\u0430 \u043C\u043E\u0436\u043D\u043E
    \u0443\u0431\u0438\u0442\u044C \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442 \u043D\u0430 \u043E\u0433\u043E\u043D\u044C.\n\n\u041D\u043E\u0432\u044B\u0435
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B - \u0433\u0443\u0430\u0432\u0430
    \u0431\u0443\u043C\n\u0432\u0437\u0440\u044B\u0432 \u043A\u043B\u0435\u0442\u043E\u043A
    \u0432 \u0440\u0430\u0434\u0438\u0443\u0441\u0435 \u043F\u043B\u044E\u0441\u0438\u043A\u0430,
    \u043D\u0435 \u0441\u0447\u0438\u0442\u0430\u044F \u043A\u043B\u0435\u0442\u043A\u0443 
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0441\u0442\u043E\u0438\u0442,
    \u043D\u0430 \u044D\u0442\u0438\u0445 \u043C\u0435\u0441\u0442\u0430\u0445 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0433\u043E\u043D\u044C \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043A\u0430
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u043D\u0430
    \u0432\u0441\u044E \u0438\u0433\u0440\u0443.\n"
