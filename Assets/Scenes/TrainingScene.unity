    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u21161\n\u0412 \u044D\u0442\u043E\u0439
    \u0438\u0433\u0440\u0435 \u0435\u0441\u0442\u044C \u0434\u0432\u0430 \u0438\u0433\u0440\u043E\u043A\u0430,\n\u043E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0438\u0445 \u043C\u043E\u0436\u0435\u0442 \u0445\u043E\u0434\u0438\u0442\u044C
    \u043D\u0430 WASD\n\u0434\u0440\u0443\u0433\u043E\u0439 \u043D\u0430 \u0441\u0442\u0440\u0435\u043B\u043E\u0447\u043A\u0438.\n\u041D\u043E
    \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u043E\u0434\u043D\u0443 \u043A\u043B\u0435\u0442\u043E\u0447\u043A\u0443
    \u0437\u0430 \u0445\u043E\u0434\n\u041F\u0440\u0438\u043B\u0438\u043F\u0430\u043D\u0438\u044F
    \u043A \u043A\u043B\u0435\u0442\u043A\u0430\u043C \u043D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0432 \u0442\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043A\u0435\n\n\u041D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043B\u044E\u0431\u0443\u044E \u043A\u043D\u043E\u043F\u043A\u0443 \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C...\n"
